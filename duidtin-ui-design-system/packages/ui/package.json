{
  "name": "@duidtin/ui",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "development": "./src/*.tsx",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./css": "./dist/index.tailwind.css"
  },
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch --no-clean",
    "check-types": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react-aria-components": "1.18.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@rsbuild/plugin-react": "^1.4.4",
    "@rslib/core": "^0.19.5",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.0",
    "tailwindcss": "4.1.18",
    "typescript": "~5.9.3",
    "vite": "^5.4.11"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
